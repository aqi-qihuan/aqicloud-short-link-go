#!/bin/bash
# commit-msg hook: 校验提交信息是否符合 Conventional Commits 规范

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(head -1 "$COMMIT_MSG_FILE")

# 允许 Merge 和 Revert 提交
if echo "$COMMIT_MSG" | grep -qE '^(Merge|Revert) '; then
    exit 0
fi

# Conventional Commits 格式: type(scope): description
# type: feat|fix|refactor|perf|test|docs|chore|ci|style|revert
# scope: 可选，括号内
# description: 必须存在且不为空
PATTERN='^(feat|fix|refactor|perf|test|docs|chore|ci|style|revert)(\([a-zA-Z0-9_/-]+\))?: .{1,}'

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    echo ""
    echo "❌ 提交信息格式不符合 Conventional Commits 规范"
    echo ""
    echo "  正确格式: type(scope): 描述"
    echo ""
    echo "  type 类型:"
    echo "    feat       新功能"
    echo "    fix        Bug 修复"
    echo "    refactor   重构"
    echo "    perf       性能优化"
    echo "    test       测试"
    echo "    docs       文档"
    echo "    chore      构建/工具"
    echo "    ci         CI/CD"
    echo "    style      代码格式"
    echo "    revert     回滚"
    echo ""
    echo "  示例:"
    echo "    feat(link): 支持自定义短链接后缀"
    echo "    fix(account): 修复 JWT 过期判断逻辑"
    echo "    refactor(common): 统一 Redis key 命名规范"
    echo ""
    echo "  当前提交信息: $COMMIT_MSG"
    echo ""
    exit 1
fi
