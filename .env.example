# AqiCloud Short-Link Go — 环境变量配置模板
# 复制此文件为 .env 并填入实际值: cp .env.example .env
# .env 已被 .gitignore 排除，不会提交到仓库

# ==================== JWT ====================
JWT_SECRET=your-jwt-secret-here

# ==================== MySQL ====================
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PWD=root

# ==================== Redis ====================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PWD=

# ==================== RabbitMQ ====================
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ==================== Kafka ====================
KAFKA_BROKERS=localhost:9092

# ==================== ClickHouse ====================
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_PORT=9000

# ==================== MinIO ====================
STORAGE_TYPE=local
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=aqicloud
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_PUBLIC_URL=http://localhost:9000/aqicloud

# ==================== RPC ====================
RPC_TOKEN=your-rpc-token-here

# ==================== SMS ====================
SMS_PROVIDER=log

# ==================== AI ====================
AI_PROVIDER=ollama
AI_API_KEY=
AI_BASE_URL=http://localhost:11434/v1
AI_MODEL=qwen3.5:9b

# ==================== Alert ====================
ALERT_TYPE=log
# ALERT_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx

# ==================== Payment (optional, leave empty for mock) ====================
# ALI_APP_ID=
# ALI_PRIVATE_KEY=
# ALI_PUBLIC_KEY=
# WECHAT_APP_ID=
# WECHAT_MCH_ID=
# WECHAT_API_KEY=
